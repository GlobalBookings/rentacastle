---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { castles, regions } from '../../data/castles';
import { blogPosts } from '../../data/blogPosts';

export function getStaticPaths() {
  return castles.map(castle => ({
    params: { slug: castle.slug },
    props: { castle },
  }));
}

const { castle } = Astro.props;
const otherCastles = castles.filter(c => c.slug !== castle.slug && c.region === castle.region).slice(0, 4);
const galleryImages = castle.images?.length ? castle.images : [castle.image];
const starWord = castle.reviewScore ? (castle.reviewScore >= 9 ? 'Exceptional' : castle.reviewScore >= 8 ? 'Very Good' : castle.reviewScore >= 7 ? 'Good' : 'Fair') : '';
const regionSlug = castle.region.toLowerCase().replace(/\s+/g, '-');
const regionData = regions.find(r => r.name === castle.region);
const relatedPosts = blogPosts.slice(0, 4);

const castleSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: castle.name,
  description: castle.description,
  image: castle.image,
  address: castle.address ? { '@type': 'PostalAddress', streetAddress: castle.address } : undefined,
  priceRange: castle.priceRange,
  numberOfRooms: castle.bedrooms || undefined,
  ...(castle.reviewScore ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: castle.reviewScore, bestRating: 10, reviewCount: castle.reviewCount || 1 } } : {}),
  ...(castle.lat && castle.lng ? { geo: { '@type': 'GeoCoordinates', latitude: castle.lat, longitude: castle.lng } } : {}),
  amenityFeature: castle.amenities?.map(a => ({ '@type': 'LocationFeatureSpecification', name: a, value: true })) || [],
  url: `https://rentacastle.uk/castles/${castle.slug}`,
};
---

<BaseLayout title={`${castle.name} | Castle Rental in ${castle.region} | RentACastle`} description={`Detailed guide to ${castle.name} in ${castle.region}. ${castle.avgPrice}. Sleeps ${castle.sleeps}. Amenities, history, photos, and direct booking links.`}>

  <div class="container">
    <Breadcrumbs items={[
      { label: 'Castles', href: '/castles' },
      { label: castle.region, href: `/regions/${regionSlug}` },
      { label: castle.name },
    ]} />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(castleSchema)} />

  <!-- Hero Gallery -->
  <section class="castle-hero">
    <div class="hero-gallery">
      <div class="hero-main-img">
        <img src={galleryImages[0]} alt={castle.name} />
      </div>
      {galleryImages.length > 1 && (
        <div class="hero-side-imgs">
          {galleryImages.slice(1, 5).map((img, i) => (
            <div class="hero-thumb">
              <img src={img} alt={`${castle.name} - View ${i + 2}`} loading="lazy" />
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="hero-overlay">
      <div class="container">
        <span class="hero-label">{castle.region}</span>
        <h1 class="hero-title">{castle.name}</h1>
        <div class="hero-meta">
          <span>{castle.type}</span>
          <span class="hero-dot">◆</span>
          <span>{castle.priceRange}</span>
          <span class="hero-dot">◆</span>
          <span>Sleeps {castle.sleeps}</span>
          {castle.reviewScore && (
            <>
              <span class="hero-dot">◆</span>
              <span class="hero-review">{castle.reviewScore}/10 {castle.reviewLabel || starWord}</span>
            </>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Strip -->
  <div class="booking-strip">
    <div class="container booking-strip-inner">
      <div class="booking-strip-info">
        <span class="strip-label">From</span>
        <span class="strip-price">{castle.avgPrice.replace('From ', '')}</span>
        <span class="strip-sep">·</span>
        <span class="strip-detail">Sleeps {castle.sleeps} guests</span>
      </div>
      <a href={castle.bookingUrl} target="_blank" rel="noopener sponsored" class="strip-cta">
        Enquire Now →
      </a>
    </div>
  </div>

  <!-- Main Content -->
  <section class="section">
    <div class="container">
      <div class="castle-layout">
        <div class="castle-main">

          <!-- Overview with Drop Cap -->
          <div class="content-section">
            <h2 class="section-title">Overview</h2>
            <div class="overview-text">
              {castle.overview ? (
                <p class="drop-cap-text">{castle.overview}</p>
              ) : (
                <p class="drop-cap-text">{castle.description}</p>
              )}
            </div>
          </div>

          <!-- Elegant Stats Row -->
          <div class="stats-row">
            <div class="stat-item">
              <span class="stat-value">{castle.sleeps}</span>
              <span class="stat-label">Guests</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-value">{castle.bedrooms}</span>
              <span class="stat-label">Bedrooms</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-value">{castle.bathrooms}</span>
              <span class="stat-label">Bathrooms</span>
            </div>
            {castle.yearBuilt && (
              <>
                <div class="stat-divider"></div>
                <div class="stat-item">
                  <span class="stat-value">{castle.yearBuilt}</span>
                  <span class="stat-label">Year Built</span>
                </div>
              </>
            )}
          </div>

          {castle.address && <p class="castle-address"><strong>Address:</strong> {castle.address}</p>}

          <!-- Review Callout -->
          {castle.reviewScore && (
            <div class="review-callout">
              <div class="review-score-box">
                <span class="review-number">{castle.reviewScore}</span>
                <span class="review-scale">/10</span>
              </div>
              <div class="review-detail">
                <strong>{castle.reviewLabel || starWord}</strong>
                {castle.reviewCount && <span class="review-count">Based on {castle.reviewCount.toLocaleString()} verified guest reviews</span>}
              </div>
            </div>
          )}

          <!-- Amenities as Pill Tags -->
          {castle.amenities && castle.amenities.length > 0 && (
            <div class="content-section">
              <h2 class="section-title">Amenities</h2>
              <div class="amenities-pills">
                {castle.amenities.map(a => (
                  <span class="amenity-pill">{a}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Castle History - Editorial -->
          {castle.history && (
            <div class="content-section">
              <h2 class="section-title">Castle History</h2>
              <div class="history-editorial">
                <p>{castle.history}</p>
              </div>
            </div>
          )}

          <!-- Key Features - Icon Style -->
          <div class="content-section">
            <h2 class="section-title">Key Features</h2>
            <div class="features-elegant">
              {castle.petFriendly && (
                <div class="feature-icon-item feature-available">
                  <span class="feature-icon">🐾</span>
                  <span class="feature-text">Pet Friendly</span>
                </div>
              )}
              {castle.weddingSuitable && (
                <div class="feature-icon-item feature-available">
                  <span class="feature-icon">💒</span>
                  <span class="feature-text">Wedding Venue</span>
                </div>
              )}
              {castle.selfCatering && (
                <div class="feature-icon-item feature-available">
                  <span class="feature-icon">🍳</span>
                  <span class="feature-text">Self Catering</span>
                </div>
              )}
              {castle.hasHotTub && (
                <div class="feature-icon-item feature-available">
                  <span class="feature-icon">🛁</span>
                  <span class="feature-text">Hot Tub</span>
                </div>
              )}
              {castle.hasPool && (
                <div class="feature-icon-item feature-available">
                  <span class="feature-icon">🏊</span>
                  <span class="feature-text">Swimming Pool</span>
                </div>
              )}
              {castle.hasWifi && (
                <div class="feature-icon-item feature-available">
                  <span class="feature-icon">📶</span>
                  <span class="feature-text">WiFi Available</span>
                </div>
              )}
              {!castle.petFriendly && (
                <div class="feature-icon-item feature-unavailable">
                  <span class="feature-icon">🐾</span>
                  <span class="feature-text">No Pets</span>
                </div>
              )}
              {!castle.hasHotTub && (
                <div class="feature-icon-item feature-unavailable">
                  <span class="feature-icon">🛁</span>
                  <span class="feature-text">No Hot Tub</span>
                </div>
              )}
              {!castle.hasPool && (
                <div class="feature-icon-item feature-unavailable">
                  <span class="feature-icon">🏊</span>
                  <span class="feature-text">No Pool</span>
                </div>
              )}
            </div>
          </div>

          <!-- Nearby Attractions -->
          {castle.nearbyAttractions && castle.nearbyAttractions.length > 0 && (
            <div class="content-section">
              <h2 class="section-title">Location & Nearby Attractions</h2>
              <p class="region-line"><strong>Region:</strong> {castle.region}</p>
              <div class="nearby-list">
                {castle.nearbyAttractions.map(a => (
                  <div class="nearby-item">
                    <span class="nearby-marker"></span>
                    <span>{a}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Booking Tip -->
          <div class="content-section" style="border-bottom: none;">
            <div class="tip-callout">
              <span class="tip-label">Booking Tip</span>
              <p>Rates at {castle.name} vary significantly by season. Summer (June–August) and school holidays see the highest demand — book 3–6 months ahead for the best availability. Autumn offers stunning foliage and lower rates, while winter provides a magical, cosy castle experience. Many castles offer midweek discounts and short-break rates outside of peak season.</p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="castle-sidebar">
          <div class="sidebar-booking-card">
            <span class="sidebar-booking-label">Price from</span>
            <div class="sidebar-booking-price">{castle.avgPrice}</div>
            <a href={castle.bookingUrl} target="_blank" rel="noopener sponsored" class="sidebar-booking-cta">
              Enquire Now →
            </a>
            <p class="sidebar-booking-note">Prices vary by date and season. Click to see current rates and availability.</p>
          </div>

          <div class="sidebar-facts-card">
            <h3>Quick Facts</h3>
            <div class="fact-row"><span>Type</span><span>{castle.type}</span></div>
            <div class="fact-row"><span>Region</span><span>{castle.region}</span></div>
            <div class="fact-row"><span>Sleeps</span><span>{castle.sleeps} guests</span></div>
            <div class="fact-row"><span>Bedrooms</span><span>{castle.bedrooms}</span></div>
            <div class="fact-row"><span>Bathrooms</span><span>{castle.bathrooms}</span></div>
            <div class="fact-row"><span>Price</span><span>{castle.priceRange} · {castle.avgPrice}</span></div>
            {castle.yearBuilt && <div class="fact-row"><span>Year Built</span><span>{castle.yearBuilt}</span></div>}
          </div>

          <div class="sidebar-plan-card">
            <div class="sidebar-plan-icon">📖</div>
            <h3>Plan Your Stay</h3>
            <p>Read our curated guides for tips on renting a castle in the UK.</p>
            <a href="/blog" class="sidebar-plan-link">Read Our Blog →</a>
          </div>

          <div class="sidebar-region-card">
            <h3>More Castles in {castle.region}</h3>
            <p>Explore other castle rentals in {castle.region}.</p>
            <a href={`/regions/${regionSlug}`} class="btn btn-outline sidebar-btn">View {castle.region} Castles →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Guides -->
  {relatedPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Castle Guides & Tips</h2>
          <p>Plan your perfect castle stay with our insider guides.</p>
        </div>
        <div class="grid grid-4">
          {relatedPosts.map(post => (
            <a href={`/blog/${post.slug}`} class="card" style="display: block;">
              <img src={post.image} alt={post.title} class="card-image" style="height: 160px;" loading="lazy" />
              <div class="card-body">
                <span class="tag">{post.category}</span>
                <h3 style="font-size: 0.95rem; margin-bottom: 0.25rem;">{post.title}</h3>
                <span style="display: inline-block; margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-accent); font-weight: 600;">Read Guide →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Castles -->
  {otherCastles.length > 0 && (
    <section class="section" style="background: var(--color-bg-alt);">
      <div class="container">
        <div class="section-header">
          <span class="related-label">More in {castle.region}</span>
          <h2>Nearby Castles</h2>
          <p>Compare other castle rentals in the region.</p>
        </div>
        <div class="related-scroll">
          {otherCastles.map(c => (
            <a href={`/castles/${c.slug}`} class="related-card">
              <div class="related-card-gold"></div>
              <div class="related-card-img">
                <img src={c.image} alt={c.name} loading="lazy" />
              </div>
              <div class="related-card-body">
                <span class="related-card-type">{c.type} · {c.priceRange}</span>
                <h3 class="related-card-name">{c.name}</h3>
                <span class="related-card-meta">Sleeps {c.sleeps} <span class="related-card-sep">◆</span> {c.avgPrice}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ===== Hero Gallery ===== */
  .castle-hero { position: relative; }

  .hero-gallery {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3px;
    max-height: 480px;
    overflow: hidden;
    border-bottom: 3px solid var(--color-accent);
  }

  .hero-main-img img {
    width: 100%;
    height: 480px;
    object-fit: cover;
  }

  .hero-side-imgs {
    display: grid;
    grid-template-rows: repeat(2, 1fr);
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .hero-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent 0%, rgba(26,26,26,0.92) 100%);
    padding: 4rem 0 2rem;
    color: white;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
    flex-wrap: wrap;
  }

  .hero-dot {
    color: var(--color-accent);
    font-size: 0.4rem;
    line-height: 1;
  }

  .hero-review {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ===== Gold Booking Strip ===== */
  .booking-strip {
    background: var(--color-accent);
    color: var(--color-primary);
    padding: 0.85rem 0;
    position: sticky;
    top: 60px;
    z-index: 50;
  }

  .booking-strip-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .booking-strip-info {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .strip-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  .strip-price {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
  }

  .strip-sep {
    opacity: 0.4;
  }

  .strip-detail {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .strip-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .strip-cta:hover {
    background: var(--color-primary-light);
    color: var(--color-white);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ===== Castle Layout ===== */
  .castle-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    align-items: start;
  }

  .content-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .content-section:last-child { border-bottom: none; }

  .section-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
  }

  /* ===== Overview with Drop Cap ===== */
  .overview-text {
    font-size: 1.02rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .drop-cap-text::first-letter {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 700;
    float: left;
    line-height: 0.85;
    margin-right: 0.12em;
    margin-top: 0.05em;
    color: var(--color-accent);
  }

  /* ===== Elegant Stats Row ===== */
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem;
    margin-bottom: 2.5rem;
    border: 1px solid rgba(201, 165, 78, 0.15);
  }

  .stat-item {
    flex: 1;
    text-align: center;
    padding: 0 1rem;
  }

  .stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
  }

  .stat-label {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-accent);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .castle-address {
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
    color: var(--color-text-light);
  }

  /* ===== Review Callout ===== */
  .review-callout {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    margin-bottom: 2.5rem;
    border: 1px solid rgba(201, 165, 78, 0.2);
    box-shadow: var(--shadow-sm);
  }

  .review-score-box {
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
    color: var(--color-primary);
    border-radius: var(--radius-md);
    padding: 0.85rem 1.1rem;
    text-align: center;
    min-width: 72px;
    flex-shrink: 0;
  }

  .review-number {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .review-scale { font-size: 0.8rem; opacity: 0.6; }

  .review-detail strong {
    display: block;
    font-size: 1.05rem;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
  }

  .review-count {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  /* ===== Amenities Pill Tags ===== */
  .amenities-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .amenity-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    background: var(--color-bg-alt);
    border: 1px solid rgba(201, 165, 78, 0.18);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all var(--transition-fast);
  }

  .amenity-pill:hover {
    background: var(--color-accent);
    color: var(--color-primary);
    border-color: var(--color-accent);
  }

  /* ===== Castle History - Editorial ===== */
  .history-editorial {
    padding: 0;
  }

  .history-editorial p {
    font-family: var(--font-heading);
    font-size: 1rem;
    line-height: 2;
    color: var(--color-text);
    font-style: italic;
  }

  /* ===== Key Features - Icon Style ===== */
  .features-elegant {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
  }

  .feature-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.25rem 0.75rem;
    border-radius: var(--radius-lg);
    transition: all var(--transition-fast);
  }

  .feature-available {
    background: var(--color-bg-alt);
    border: 1px solid rgba(201, 165, 78, 0.15);
  }

  .feature-unavailable {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.06);
    opacity: 0.45;
  }

  .feature-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .feature-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .feature-unavailable .feature-text {
    color: var(--color-text-light);
  }

  /* ===== Nearby Attractions ===== */
  .region-line {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .nearby-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.65rem;
  }

  .nearby-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.88rem;
    color: var(--color-text);
    padding: 0.5rem 0;
  }

  .nearby-marker {
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ===== Booking Tip ===== */
  .tip-callout {
    border: 1px solid var(--color-accent);
